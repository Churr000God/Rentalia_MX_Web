# ==============================================
# RENTALIA.MX - Variables de Entorno
# ==============================================

# Entorno de ejecución
NODE_ENV=development
PORT=3000

# Base de datos (futuro)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rentalia_db
DB_USER=rentalia_user
DB_PASSWORD=your_secure_password

# Redis (futuro - cache/sesiones)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (futuro - autenticación)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Email — Correo saliente (FastAPI usa smtplib con STARTTLS)
SMTP_HOST=mail.rentalia.mx
SMTP_PORT=587
SMTP_USER=diego_ti@rentalia.mx
SMTP_PASSWORD=your_email_password
MAIL_FROM=diego_ti@rentalia.mx
MAIL_TO=hola@rentalia.mx

# Servicios externos (futuro)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# WhatsApp Business API (futuro)
WHATSAPP_TOKEN=your_whatsapp_business_token
WHATSAPP_PHONE_ID=your_phone_number_id

# Cloudinary (futuro - imágenes)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# URLs
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:8081

# Logs
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Seguridad
CORS_ORIGIN=http://localhost:8080
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoreo (futuro)
SENTRY_DSN=your_sentry_dsn_here

# Desarrollo
DEBUG=rentalia:*